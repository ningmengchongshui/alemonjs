{
  "name": "afloat",
  "version": "1.0.9",
  "description": "afloat",
  "author": "ningmengchongshui",
  "license": "GPL-2.0",
  "type": "module",
  "types": "types",
  "main": "lib/index.js",
  "scripts": {
    "tsc": "tsc",
    "tsc:bin": "tsc --module NodeNext  bin/afloat.ts",
    "tsc:logs": "tsc --module NodeNext --declaration ./logs.ts",
    "tsc:run": "tsc --module NodeNext --declaration ./run.ts",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.ts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@rollup/plugin-multi-entry": "^6.0.0",
    "@rollup/plugin-typescript": "^11.1.3",
    "nodemon": "^3.0.1",
    "rollup": "^3.28.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.2.4",
    "@types/nodemon": "^1.19.6",
    "@types/progress": "^2.0.5",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.8"
  },
  "bin": {
    "afloat": "./bin/afloat.js"
  },
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./types/index.d.ts"
    },
    "./run": {
      "import": "./run.js",
      "types": "./run.d.ts"
    },
    "./logs": {
      "import": "./logs.js",
      "types": "./logs.d.ts"
    }
  },
  "files": [
    "bin/afloat.js",
    "run.js",
    "run.d.ts",
    "log.js",
    "log.d.ts",
    "lib",
    "types",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "alemonjs"
  ]
}