{
  "compilerOptions": {
    "baseUrl": "./",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "preserveConstEnums": true,
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "include": [
    "bin/index.ts"
  ],
  "exclude": [
    "node_modules",
    "bin/template"
  ]
}