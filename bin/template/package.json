{
  "name": "alemonjs",
  "version": "1.0.0",
  "description": "阿柠檬机器人",
  "author": "ningmengchongshui",
  "license": "GPL-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "afloat dev",
    "image": "afloat image",
    "build": "afloat build",
    "start": "afloat pm2 startOrRestart pm2.config.cjs",
    "stop": "afloat pm2 stop pm2.config.cjs",
    "restart": "afloat pm2 restart pm2.config.cjs",
    "delete": "afloat pm2 delete pm2.config.cjs",
    "logs": "afloat pm2 logs",
    "list": "afloat pm2 list",
    "startup": "afloat pm2 startup",
    "update": "afloat pm2 update",
    "monit": "afloat pm2 monit",
    "save": "afloat pm2 save",
    "kill": "afloat pm2 kill",
    "format": "prettier --write .",
    "pull:l": "find . -type d -name '.git' -execdir git pull --all \\;",
    "pull:w": "cd application && for /d %i in (*) do (echo Updating %i && cd %i && git pull && cd ..) "
  },
  "dependencies": {
    "ioredis": "^5.3.2",
    "mysql2": "^3.5.2",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "afloat": "^1.2.0-rc.9",
    "alemonjs": "^1.2.0-rc.23",
    "prettier": "^3.1.1"
  },
  "workspaces": [
    "plugins/*"
  ],
  "engines": {
    "node": ">=16.14.0"
  }
}
