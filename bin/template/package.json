{
  "name": "alemonb",
  "version": "1.0.0",
  "description": "阿柠檬机器人",
  "author": "ningmengchongshui",
  "license": "GPL-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "nuxt": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "server": "node ./.output/server/index.mjs",
    "dev": "nodemon src/main.ts",
    "app": "ts-node src/main.ts",
    "login": "ts-node src/main.ts login",
    "start": "pm2 startOrRestart pm2.config.cjs",
    "stop": "pm2 stop pm2.config.cjs",
    "restart": "pm2 restart pm2.config.cjs",
    "delete": "pm2 delete pm2.config.cjs",
    "logs": "pm2 logs alemonb",
    "list": "pm2 list",
    "startup": "pm2 startup",
    "update": "pm2 update",
    "monit": "pm2 monit",
    "save": "pm2 save",
    "kill": "pm2 kill",
    "pull:l": "find . -type d -name '.git' -execdir git pull --all \\;",
    "pull:w": "git pull && cd plugins && for /d %i in (*) do (echo Updating %i && cd %i && git pull && cd ..)",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.ts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "alemon-bot": "^1.1.8",
    "alemon-ffmpeg": "^1.0.1",
    "alemon-redis": "^1.0.5"
  },
  "devDependencies": {
    "@nuxt/bridge": "^0.10.1",
    "@nuxt/devtools": "latest",
    "@nuxt/typescript-build": "^3.0.1",
    "@vant/nuxt": "^1.0.3",
    "nuxt": "^3.7.4",
    "vant": "^4.7.1",
    "less": "^4.2.0",
    "vue": "^3.3.4",
    "vue-router": "^4.2.5",
    "query-string": "^8.1.0",
    "@types/node": "^20.3.1",
    "@types/ws": "^8.5.5",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "nodemon": "^2.0.22",
    "pm2": "^5.3.0",
    "pre-commit": "^1.2.2",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.1",
    "typescript": ">=5.0.4 <5.1.0"
  },
  "pre-commit": [
    "lint",
    "format"
  ],
  "workspaces": [
    "application/*",
    "example"
  ],
  "engines": {
    "node": ">=16.3.0"
  }
}