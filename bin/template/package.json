{
  "name": "alemonjs",
  "version": "1.0.0",
  "description": "阿柠檬机器人",
  "author": "ningmengchongshui",
  "license": "GPL-2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "afloat dev",
    "build": "afloat build",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.ts --fix --ignore-path .gitignore",
    "pull:l": "find . -type d -name '.git' -execdir git pull --all \\;",
    "pull:w": "cd application && for /d %i in (*) do (echo Updating %i && cd %i && git pull && cd ..) ",
    "start": "pm2 startOrRestart pm2.config.cjs",
    "stop": "pm2 stop pm2.config.cjs",
    "restart": "pm2 restart pm2.config.cjs",
    "delete": "pm2 delete pm2.config.cjs",
    "logs": "pm2 logs",
    "list": "pm2 list",
    "startup": "pm2 startup",
    "update": "pm2 update",
    "monit": "pm2 monit",
    "save": "pm2 save",
    "kill": "pm2 kill"
  },
  "dependencies": {
    "art-template": "^4.13.2",
    "ioredis": "^5.3.2",
    "mysql2": "^3.5.2",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  },
  "workspaces": [
    "plugins/*"
  ],
  "engines": {
    "node": ">=16.14.0"
  }
}